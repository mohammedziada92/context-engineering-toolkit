# ── App ──────────────────────────────────────────────────
ENVIRONMENT=development

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ── Database ─────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── OpenRouter (REMOVED — CET is BYOK, users supply their own key in Settings) ──
OPENROUTER_API_KEY=REMOVED-CET-IS-BYOK

# ── Models ───────────────────────────────────────────────
MODEL_QUALITY=anthropic/claude-sonnet-4-6
MODEL_AGENT=z-ai/glm-5
MODEL_BUDGET=google/gemini-3.1-pro-preview

# ── Embeddings ───────────────────────────────────────────
EMBEDDING_MODEL=baai/bge-m3
EMBEDDING_DIMENSIONS=1024

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── OAuth (optional) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Error Tracking (optional) ───────────────────────────
SENTRY_DSN=

# ── Vault Encryption (generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())") ──
VAULT_ENCRYPTION_KEY=generate-with-python-command-above

# ── Docker Compose local dev keys ──────────────────────────
ANON_KEY=your-supabase-anon-key-here
SERVICE_KEY=your-supabase-service-role-key-here
AUTH_JWT_SECRET=your-jwt-secret-here
DB_ENC_KEY=your-db-encryption-key-here
SECRET_KEY_BASE=your-secret-key-base-here
